# Example environment variables for deployment
# Copy to .env or set in Railway project settings

# Next.js / App
NODE_ENV=production
PORT=3000
NEXTAUTH_URL=https://your-app.example.com
NEXTAUTH_SECRET=change-me

# Database
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Socket / server
NEXT_PUBLIC_SOCKET_URL=https://your-socket.example.com
PORT_SOCKET=3001
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.example.com

# JWT / auth (server uses JWT_SECRET or NEXTAUTH_SECRET)
JWT_SECRET=change-me

# Firebase admin (service account fields)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
# For private key, replace newlines with \n when setting in environment
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FAIL_FAST_ON_MISSING_FIREBASE=false

# Prisma / other
# If using libsql or other providers
# LIBSQL_URL=
# Database (SQLite for local dev, use file: prefix for local, libsql:// for Turso/production)
DATABASE_URL=file:./prisma/dev.db

# Google Maps API Key (get from console.cloud.google.com)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here_min_32_chars

# SMTP (for password reset emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=mendeezkarl@gmail.com
SMTP_PASS=vlqz enbg hlrr ufnk
SMTP_FROM="NUTECH BusTrack <f24605023@nutech.edu.pk>"

# Socket.io Server URL (the standalone Express server)
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# JWT Secret for the Socket.io server
JWT_SECRET=your_jwt_secret_here

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase Cloud Messaging (get from console.firebase.google.com)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your_vapid_key

# Firebase Admin (Service Account - get from Project Settings > Service Accounts)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="your_private_key"

