{
  "name": "nutech-bustrack",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "^20.19 || ^22.12 || >=24.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "dev:https": "next dev --experimental-https -H 0.0.0.0 -p 3000",
    "prebuild": "prisma migrate deploy && prisma generate",
    "build": "prisma generate && next build && npm run postbuild",
    "postbuild": "cd server && npm install && npm run build && cd ..",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:migrate": "npx prisma migrate dev",
    "db:reset": "npx prisma migrate reset --force && npx tsx prisma/seed.ts",
    "server:dev": "cd server && npm run dev",
    "server:build": "cd server && npm run build",
    "mobile:cap:add:android": "npx cap add android",
    "mobile:cap:sync": "npx cap sync android",
    "mobile:cap:copy": "npx cap copy android",
    "mobile:android:open": "npx cap open android",
    "mobile:android:live": "npx cap run android -l --host=0.0.0.0 --port=3000 --forwardPorts 3000:3000",
    "mobile:android:live:sync": "npm run mobile:cap:sync && npx cap run android -l --host=0.0.0.0 --port=3000 --forwardPorts 3000:3000",
    "mobile:android:live:https": "npx cap run android -l --https --host=0.0.0.0 --port=3000 --forwardPorts 3000:3000",
    "mobile:android:live:sync:https": "npm run mobile:cap:sync && npx cap run android -l --https --host=0.0.0.0 --port=3000 --forwardPorts 3000:3000",
    "mobile:android:logs": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$adb = (Get-Command adb -ErrorAction SilentlyContinue).Source; if (-not $adb) { $sdkAdb = Join-Path $env:LOCALAPPDATA 'Android\\Sdk\\platform-tools\\adb.exe'; if (Test-Path $sdkAdb) { $adb = $sdkAdb } }; if (-not $adb) { Write-Host 'ADB not found. Install Android platform-tools or add adb to PATH.'; exit 1 }; & $adb logcat\""
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@libsql/client": "^0.17.2",
    "@prisma/adapter-libsql": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@sentry/nextjs": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "firebase": "^12.12.1",
    "firebase-admin": "^13.8.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.400.0",
    "next": "15.5.14",
    "next-auth": "5.0.0-beta.30",
    "nodemailer": "^7.0.13",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "prisma": "^7.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1",
    "socket.io-client": "^4.7.5",
    "tailwind-merge": "^2.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^15.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^20.14.11",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^2.0.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.5.14",
    "happy-dom": "^14.0.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vitest": "^2.0.0"
  }
}
